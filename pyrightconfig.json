{
  "typeCheckingMode": "standard",
  "pythonVersion": "3.12",
  "include": [
    "backend/app"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    ".venv",
    "backend/.venv",
    "**/tests",
    "backend/alembic"
  ],
  "extraPaths": [
    "backend"
  ],
  "reportMissingImports": "warning",
  "reportMissingModuleSource": "none"
}
