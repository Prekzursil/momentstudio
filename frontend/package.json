{
  "name": "adrianaart-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prestart": "node scripts/generate-config.mjs",
    "start": "node --disable-warning=DEP0060 ./node_modules/@angular/cli/bin/ng.js serve --proxy-config proxy.conf.json",
    "prebuild": "node scripts/generate-config.mjs",
    "build": "node --disable-warning=DEP0060 ./node_modules/@angular/cli/bin/ng.js build",
    "pretest": "node scripts/generate-config.mjs",
    "test": "node --disable-warning=DEP0060 ./node_modules/@angular/cli/bin/ng.js test",
    "pretest:coverage": "node scripts/generate-config.mjs",
    "test:coverage": "node --disable-warning=DEP0060 ./node_modules/@angular/cli/bin/ng.js test --code-coverage --watch=false --browsers=ChromeHeadlessNoSandbox",
    "posttest:coverage": "node scripts/diff-coverage.mjs",
    "test:coverage:diff": "node scripts/diff-coverage.mjs",
    "test:coverage:diff-unit": "node --test scripts/diff-coverage.spec.mjs",
    "guard:render-mode": "node scripts/render-mode-guard.mjs",
    "test:guard:render-mode": "node --test scripts/render-mode-guard.spec.mjs",
    "test:lint-ban-proof": "node --test scripts/lint-ban-proof.spec.mjs",
    "lint": "eslint .",
    "i18n:check": "node scripts/check-i18n.mjs",
    "e2e": "playwright test",
    "e2e:chromatic": "playwright test --config=playwright.chromatic.config.ts --project=chromium",
    "dev:ssr": "node --disable-warning=DEP0060 ./node_modules/@angular/cli/bin/ng.js run app:serve-ssr",
    "serve:ssr": "node scripts/prepare-ssr-runtime.cjs && node dist/app/server/main.js",
    "build:ssr": "node --disable-warning=DEP0060 ./node_modules/@angular/cli/bin/ng.js build && node --disable-warning=DEP0060 ./node_modules/@angular/cli/bin/ng.js run app:server && node scripts/prepare-ssr-runtime.cjs",
    "start:ssr": "npm run serve:ssr",
    "prerender": "ng run app:prerender"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.18",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/platform-browser-dynamic": "^21.2.18",
    "@angular/platform-server": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@angular/service-worker": "^21.2.18",
    "@angular/ssr": "^21.2.19",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@nuintun/qrcode": "^5.0.3",
    "@sentry/browser": "^10.66.0",
    "@toast-ui/editor": "^3.2.2",
    "diff": "^8.0.2",
    "dompurify": "^3.4.12",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.13.9",
    "marked": "^17.0.4",
    "rxjs": "^7.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@applitools/eyes-playwright": "^1.47.11",
    "@chromatic-com/playwright": "^0.14.11",
    "@codecov/bundle-analyzer": "^1.9.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.15",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.13.3",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.5.4",
    "browser-sync": "^3.0.0",
    "chokidar": "^3.6.0",
    "chromatic": "^13.3.2",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "glob-parent": "^5.1.2",
    "jasmine-core": "~5.13.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "karma-junit-reporter": "^2.0.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "readdirp": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "@toast-ui/editor": {
      "dompurify": "3.4.11"
    },
    "fastify": "5.8.5",
    "hono": "4.12.25",
    "lodash": "4.18.0",
    "serialize-javascript": "7.0.5",
    "tar": "7.5.16",
    "undici": "7.28.0",
    "esbuild": "0.28.1",
    "vite": "7.3.5",
    "storybook": "8.6.17",
    "@babel/core": "7.29.6",
    "http-proxy-middleware": "3.0.7",
    "piscina": "5.2.0",
    "uuid": "11.1.1"
  }
}
