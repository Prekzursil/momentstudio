{
  "$comment": "Shared theme-token validation corpus (momentstudio P1a WU2). SINGLE source of truth consumed by BOTH the TS validator spec (frontend/src/app/core/theme/token-validation.spec.ts) and the Python mirror test (backend/tests/test_theme_validation.py). Every case must classify identically (ok/reject) on client and server. Wire format is frozen by the WU0 spike memo §4: Tailwind-consumed color = bare space-separated R G B triplet; font-family = curated enum; numeric+unit for sizes/spacing. Backslash sequences below are CSS unicode escapes (JSON-escaped) used to prove the decode-first CSS-safe encoder cannot be bypassed.",
  "cases": [
    { "name": "--background", "value": "255 255 255", "expect": "ok", "why": "canonical R G B triplet, white page canvas" },
    { "name": "--text", "value": "51 65 85", "expect": "ok", "why": "slate-700 body copy triplet" },
    { "name": "--accent", "value": "79 70 229", "expect": "ok", "why": "indigo-600 accent triplet" },
    { "name": "--overlay", "value": "0 0 0", "expect": "ok", "why": "zero channels are valid" },
    { "name": "--surface-inverse", "value": "15 23 42", "expect": "ok", "why": "slate-900 inverse surface" },
    { "name": "--border", "value": "226 232 240", "expect": "ok", "why": "max-ish channels within range" },
    { "name": "--background-50", "value": "248 250 252", "expect": "ok", "why": "server-emitted color ramp step" },
    { "name": "--surface-800", "value": "30 41 59", "expect": "ok", "why": "server-emitted color ramp step" },
    { "name": "--text-500", "value": "100 116 139", "expect": "ok", "why": "server-emitted color ramp step" },
    { "name": "--border-200", "value": "226 232 240", "expect": "ok", "why": "server-emitted color ramp step" },
    { "name": "--font-body", "value": "Inter, system-ui, -apple-system, sans-serif", "expect": "ok", "why": "curated body font-family enum member" },
    { "name": "--font-heading", "value": "Cinzel, ui-serif, Georgia, serif", "expect": "ok", "why": "curated heading font-family enum member" },
    { "name": "--font-body", "value": "system-ui, sans-serif", "expect": "ok", "why": "curated system stack enum member" },
    { "name": "--font-size-base", "value": "1.125rem", "expect": "ok", "why": "simple numeric+unit" },
    { "name": "--font-size-base", "value": "clamp(15px, 1.2vw + 12px, 18px)", "expect": "ok", "why": "safe clamp math expression" },
    { "name": "--space-md", "value": "16px", "expect": "ok", "why": "simple spacing numeric+unit" },
    { "name": "--space-lg", "value": "1.5rem", "expect": "ok", "why": "simple spacing numeric+unit" },
    { "name": "--space-sm", "value": "0.5rem", "expect": "ok", "why": "fractional spacing numeric+unit" },
    { "name": "--space-2xl", "value": "clamp(2rem, 4vw, 4rem)", "expect": "ok", "why": "safe clamp spacing expression" },

    { "name": "--unknown-token", "value": "1 2 3", "expect": "reject", "why": "name not in the closed registry" },
    { "name": "--Bad_Name", "value": "1 2 3", "expect": "reject", "why": "underscore fails the name regex" },
    { "name": "background", "value": "1 2 3", "expect": "reject", "why": "missing -- prefix" },
    { "name": "--", "value": "1 2 3", "expect": "reject", "why": "empty token name after prefix" },
    { "name": "--x{}", "value": "1 2 3", "expect": "reject", "why": "braces in name fail the regex" },
    { "name": "--space-huge", "value": "1rem", "expect": "reject", "why": "spacing key not in the ramp enum" },
    { "name": "--text-999", "value": "1 2 3", "expect": "reject", "why": "color ramp shade not in the allowed step enum" },

    { "name": "--text", "value": "#0f172a", "expect": "reject", "why": "hex in a Tailwind-consumed triplet slot silently fails to paint" },
    { "name": "--text", "value": "rgb(15, 23, 42)", "expect": "reject", "why": "rgb() wrapper not allowed for triplet tokens" },
    { "name": "--text", "value": "15,23,42", "expect": "reject", "why": "commas not allowed in a triplet" },
    { "name": "--text", "value": "300 0 0", "expect": "reject", "why": "channel out of 0-255 range" },
    { "name": "--text", "value": "15 23", "expect": "reject", "why": "only two channels" },
    { "name": "--text", "value": "15 23 42 44", "expect": "reject", "why": "four channels" },
    { "name": "--background", "value": "15  23  42", "expect": "reject", "why": "double space between channels" },
    { "name": "--text", "value": "015 23 42", "expect": "reject", "why": "leading-zero padded channel" },

    { "name": "--font-body", "value": "Comic Sans MS", "expect": "reject", "why": "not a curated font-family enum member" },
    { "name": "--font-heading", "value": "Arial", "expect": "reject", "why": "not a curated font-family enum member" },

    { "name": "--space-md", "value": "16", "expect": "reject", "why": "numeric value missing a unit" },
    { "name": "--font-size-base", "value": "calc(16px + red)", "expect": "reject", "why": "non-numeric token inside a math expression" },
    { "name": "--space-md", "value": "16px; color:red", "expect": "reject", "why": "semicolon enables a declaration breakout" },
    { "name": "--font-size-base", "value": "expression(alert(1))", "expect": "reject", "why": "legacy CSS expression() sink" },

    { "name": "--text", "value": "15 23 42) } html{color:red}", "expect": "reject", "why": "key/rule breakout via ) } {" },
    { "name": "--overlay", "value": "0 0 0 } body{display:none}", "expect": "reject", "why": "rule breakout via }" },
    { "name": "--font-body", "value": "</style><script>alert(1)</script>", "expect": "reject", "why": "</style> injection contains <" },
    { "name": "--accent", "value": "\\3c script\\3e", "expect": "reject", "why": "unicode-escaped < survives decode-first then rejects" },
    { "name": "--font-body", "value": "Inter\\3b color:red", "expect": "reject", "why": "unicode-escaped semicolon" },
    { "name": "--font-body", "value": "@import url(evil.css)", "expect": "reject", "why": "@import sink" },
    { "name": "--font-body", "value": "javascript:alert(1)", "expect": "reject", "why": "javascript: scheme" },
    { "name": "--font-heading", "value": "url(javascript:alert(1))", "expect": "reject", "why": "url() with a disallowed scheme and no url-typed token" },
    { "name": "--font-body", "value": "url(https://cdn.example.com/f.woff2)", "expect": "reject", "why": "url() rejected because no P1a token permits url values" },
    { "name": "--font-body", "value": "Inter\u0001bell", "expect": "reject", "why": "control character" }
  ]
}
